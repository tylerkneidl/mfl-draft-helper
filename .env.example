# --- MFL ---
MFL_YEAR=2026
MFL_HOST=www45.myfantasyleague.com
MFL_LEAGUE_ID=41969
MFL_USER=your_mfl_username
MFL_PASS=your_mfl_password
MFL_FRANCHISE_ID=            # leave blank, fill from `npm run inspect`

# --- Slack ---
# Create an app at api.slack.com/apps (from scratch). Bot scope: chat:write.
# Enable Interactivity -> Request URL = https://<your-railway-domain>/slack/interactivity
SLACK_BOT_TOKEN=             # xoxb-...
SLACK_SIGNING_SECRET=        # verifies inbound button clicks
SLACK_CHANNEL=               # channel id (e.g. C0123) or your DM id

# --- Anthropic (per-pick + trade reasoning) ---
ANTHROPIC_API_KEY=

# --- Safety / behavior ---
DRY_RUN=true                 # true = never writes a pick to MFL (log only)
AUTO_PICK=false              # arm auto-pick fallback only when ready
CANDIDATE_COUNT=6
PORT=3000
